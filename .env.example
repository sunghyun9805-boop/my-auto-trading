# 한국투자증권(KIS) Open API 인증 정보
# 아래 값들을 본인의 정보로 채운 뒤 파일명을 `.env`로 저장하세요.

# 실전투자 / 모의투자 구분 ("real" 또는 "paper")
KIS_ENV=paper

# App Key (한국투자증권 개발자센터에서 발급)
KIS_APP_KEY=your_app_key_here

# App Secret (한국투자증권 개발자센터에서 발급)
KIS_APP_SECRET=your_app_secret_here

# 계좌번호 앞 8자리 (CANO)
KIS_ACCOUNT_NO=12345678

# 계좌번호 뒤 2자리 상품코드 (ACNT_PRDT_CD), 보통 "01"
KIS_ACCOUNT_PRODUCT_CODE=01

# API 베이스 URL (수정할 필요 없음)
KIS_REAL_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_URL=https://openapivts.koreainvestment.com:29443

# ── 텔레그램 모바일 대시보드 (선택) ─────────────────────────────
# 둘 중 하나라도 비어 있으면 텔레그램 알림은 자동으로 비활성화된다.
# 봇 토큰: @BotFather 에서 발급
TELEGRAM_TOKEN=
# 채팅 ID: @userinfobot 또는 getUpdates API 로 확인
TELEGRAM_CHAT_ID=
